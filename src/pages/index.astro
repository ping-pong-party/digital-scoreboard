---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ping Pong Party">
  <main class="min-h-screen flex items-center justify-center p-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-6xl font-bold mb-8 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        Ping Pong Party
      </h1>
      <p class="text-2xl mb-12 text-gray-600 dark:text-gray-400">
        Real-time scoreboard and ELO tracker
      </p>

      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <a
          href="/kiosk"
          class="block p-8 bg-white dark:bg-gray-800 rounded-lg shadow-lg hover:shadow-xl transition-shadow border-2 border-transparent hover:border-blue-500"
        >
          <h2 class="text-3xl font-bold mb-4">Kiosk</h2>
          <p class="text-gray-600 dark:text-gray-400">Keyboard-driven scoreboard for TV display</p>
        </a>

        <a
          href="/podium"
          class="block p-8 bg-white dark:bg-gray-800 rounded-lg shadow-lg hover:shadow-xl transition-shadow border-2 border-transparent hover:border-purple-500"
        >
          <h2 class="text-3xl font-bold mb-4">Podium</h2>
          <p class="text-gray-600 dark:text-gray-400">Today's top players leaderboard</p>
        </a>

        <a
          href="/players"
          class="block p-8 bg-white dark:bg-gray-800 rounded-lg shadow-lg hover:shadow-xl transition-shadow border-2 border-transparent hover:border-green-500"
        >
          <h2 class="text-3xl font-bold mb-4">Players</h2>
          <p class="text-gray-600 dark:text-gray-400">Manage players and ratings</p>
        </a>
      </div>

      <div class="text-center">
        <a
          href="/demo"
          class="inline-block px-8 py-4 bg-gradient-to-r from-pink-500 to-purple-600 text-white font-bold rounded-lg shadow-lg hover:shadow-xl transition-all"
        >
          🚀 React Integration Demo
        </a>
      </div>
    </div>
  </main>
</Layout>
