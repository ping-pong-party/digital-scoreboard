---
import Layout from '../layouts/Layout.astro';
import MatchHistory from '../components/matches/MatchHistory';
---

<Layout title="Match History - Ping Pong Party">
  <main class="min-h-screen bg-gradient-to-br from-gray-900 to-gray-800 p-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-8 text-center">
        <h1 class="text-7xl font-black text-white mb-4">🎮 Match History</h1>
        <p class="text-2xl text-gray-400">Complete record of all matches played</p>
      </div>

      <!-- Match History Component -->
      <MatchHistory client:load />

      <!-- Info Box -->
      <div class="mt-12 bg-blue-900/30 border-2 border-blue-500/50 rounded-lg p-6">
        <h3 class="text-2xl font-bold text-blue-400 mb-4">📖 About Match History</h3>
        <ul class="space-y-2 text-xl text-gray-300">
          <li><strong>Completed Matches:</strong> Shows final score and rating changes</li>
          <li><strong>In Progress:</strong> Yellow border indicates ongoing matches</li>
          <li><strong>Rated vs Unrated:</strong> Only rated matches affect ELO ratings</li>
          <li><strong>Rating Changes:</strong> Green = gain, Red = loss</li>
        </ul>
      </div>

      <div class="text-center mt-12">
        <a href="/" class="text-2xl text-blue-400 hover:text-blue-300 transition-colors">
          ← Back to Home
        </a>
      </div>
    </div>
  </main>
</Layout>
