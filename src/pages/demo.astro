---
import Layout from '../layouts/Layout.astro';
import Counter from '../components/Counter';
---

<Layout title="React Demo - Ping Pong Party">
  <main class="min-h-screen bg-gradient-to-br from-gray-900 to-gray-800 p-8">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-6xl font-black text-white text-center mb-12">
        React Integration Demo
      </h1>

      <div class="space-y-8">
        <!-- Client-side interactive React component -->
        <div class="text-center mb-6">
          <span class="inline-block px-4 py-2 bg-blue-600 text-white rounded-full text-sm font-bold">
            Interactive React Component
          </span>
        </div>

        <Counter client:load label="Score A" initialCount={0} />

        <Counter client:load label="Score B" initialCount={0} />

        <div class="text-center text-gray-400 mt-12">
          <p class="text-xl mb-4">
            This demonstrates that React is working in Astro!
          </p>
          <p>
            The counters above are interactive React components using <code class="bg-gray-700 px-2 py-1 rounded">client:load</code>
          </p>
        </div>

        <div class="text-center mt-8">
          <a href="/" class="text-2xl text-blue-400 hover:text-blue-300 transition-colors">
            ← Back to Home
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  code {
    font-family: 'Courier New', monospace;
  }
</style>
