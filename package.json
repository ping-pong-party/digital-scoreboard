    "start": "node dist/server/index.js",
    "type-check": "tsc --noEmit",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.5",
    "@astrojs/tailwind": "^6.0.2",
    "@auth0/auth0-spa-js": "^2.17.1",
    "astro": "5.18.1",
    "sql.js": "^1.14.1",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/sql.js": "^1.4.9",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
