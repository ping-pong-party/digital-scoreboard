{
  "name": "@ping-pong-party/digital-scoreboard",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n astro,server -c cyan,green \"astro dev\" \"tsx watch src/server/index.ts\"",
